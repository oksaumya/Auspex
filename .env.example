# Required for LLM inference. Without it, the system falls back to deterministic heuristics.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.1

# Optional — improves retrieval quality
COHERE_API_KEY=

# Optional — only needed if exposing the webhook to GitHub
GITHUB_WEBHOOK_SECRET=

# Optional — enables real PR file fetching when webhook payload omits inline files
GITHUB_TOKEN=

# Optional — LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=auspex

# Optional overrides
PROJECT_ROOT=
CHECKPOINT_DB_PATH=
RATE_LIMIT_PER_MINUTE=60
MAX_DIFF_CHARS=100000
